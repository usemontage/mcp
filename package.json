{
  "name": "@montageai/mcp",
  "version": "0.1.0",
  "description": "MCP server for the Montage API - production UI on demand",
  "license": "MIT",
  "homepage": "https://usemontage.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/usemontage/mcp.git"
  },
  "keywords": [
    "montage",
    "ai",
    "mcp",
    "model-context-protocol",
    "ui",
    "agent"
  ],
  "type": "module",
  "bin": {
    "montage-mcp": "dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "proof:agents": "npm run build && tsx examples/agents/mcp-client-smoke.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
